# Public base URL that the Android app should use.
PUBLIC_BASE_URL=https://onsrooster.stefhermans.nl

# Backend listener configuration.
APP_HOST=0.0.0.0
APP_PORT=8080
DATA_DIR=./data
LOG_LEVEL=INFO
TZ=Europe/Amsterdam

# ONS automation defaults.
DEFAULT_LOGIN_URL=https://landvanhorne.startmetons.nl/?jump=https%3A%2F%2Flandvanhorne.hasmoves.com%2F
SYNC_INTERVAL_MINUTES=360
SMS_TIMEOUT_SECONDS=150
LOGIN_TIMEOUT_SECONDS=30
PLAYWRIGHT_HEADLESS=true
POST_LOGIN_URL=
ROSTER_URL=

# Optional hardening values.
SETUP_SECRET=
DEBUG_TOKEN=
ADMIN_TOKEN=
STORAGE_KEY=

# Firebase service account configuration for FCM.
# Optional when the service account JSON already contains a project_id.
FCM_PROJECT_ID=
# Host path used by docker-compose.portainer.secrets.yml on the Docker server.
FCM_SERVICE_ACCOUNT_HOST_PATH=
FCM_SERVICE_ACCOUNT_FILE=
FCM_SERVICE_ACCOUNT_JSON=
